<link rel="stylesheet" href="/css/show.css">
<link rel="stylesheet" href="/css/booking.css">
<link rel="stylesheet" href="/css/delete-confirm.css">
<link rel="stylesheet" href="/css/button-style.css">
<% layout("/layouts/boilerplate") %>
    <style>
        @media (max-width:768px) {
            .alert {
                left: 17%;
            }
        }
    </style>
    <script>
        const mapToken = "<%= process.env.MAP_TOKEN %>";
        const listing = JSON.parse(`<%- JSON.stringify(listing) %>`);
    </script>
    <div class="row mt-3 show-main">
        <div class="show-body">
            <div class="col-10 offset-1">
                <h3 class="ms-3">
                    <%= listing.title %>
                </h3>
                <!-- Property Type Badge -->
                <% if(listing.propertyType) { %>
                    <span class="property-type-badge ms-3">
                        <i class="fa-solid fa-house"></i> <%= listing.propertyType %>
                    </span>
                <% } %>
            </div>

            <!-- Hero Image -->
            <div class="card col-10 offset-1 show-card listing-card">
                <div class="show-card-img">
                    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
                </div>
            </div>

            <!-- Two-column layout: Info + Booking Widget -->
            <div class="col-10 offset-1">
                <div class="show-two-col">
                    <!-- Left: Listing Details -->
                    <div class="show-left-col">
                        <div class="card-body ms-1">
                            <p class="card-text"><b>Owned by :</b> <b><i>@<%= listing.owner?.username %></i></b></p>
                            <p class="card-text"><b>Description :</b>
                                <%= listing.description %>
                            </p>
                            <p class="card-text"><b>Price :</b> &#8377; <%= listing.price.toLocaleString("en-In") %> / night
                            </p>
                            <p class="card-text"><b>Location :</b>
                                <%= listing.location %>, <%= listing.country %> <i class="fa-solid fa-location-dot"
                                            style="margin-right: 1rem; font-size: 1.25rem;"></i>
                            </p>
                            <p class="card-text"><b>Category :</b>
                                <%= listing.category.slice(",").join(", ") %> </p>
                        </div>

                        <!-- Property Highlights -->
                        <div class="property-highlights">
                            <div class="highlight-item">
                                <i class="fa-solid fa-users"></i>
                                <span><%= listing.maxGuests || 4 %> guests</span>
                            </div>
                            <div class="highlight-item">
                                <i class="fa-solid fa-bed"></i>
                                <span><%= listing.bedrooms || 1 %> bedroom<%= (listing.bedrooms || 1) > 1 ? 's' : '' %></span>
                            </div>
                            <div class="highlight-item">
                                <i class="fa-solid fa-bed"></i>
                                <span><%= listing.beds || 1 %> bed<%= (listing.beds || 1) > 1 ? 's' : '' %></span>
                            </div>
                            <div class="highlight-item">
                                <i class="fa-solid fa-bath"></i>
                                <span><%= listing.bathrooms || 1 %> bath<%= (listing.bathrooms || 1) > 1 ? 's' : '' %></span>
                            </div>
                        </div>

                        <!-- Amenities -->
                        <% if(listing.amenities && listing.amenities.length > 0) { %>
                            <div class="amenities-section">
                                <h4><i class="fa-solid fa-sparkles"></i> What this place offers</h4>
                                <div class="amenities-grid">
                                    <% const amenityIcons = {
                                        'WiFi': 'fa-solid fa-wifi',
                                        'Kitchen': 'fa-solid fa-kitchen-set',
                                        'Pool': 'fa-solid fa-person-swimming',
                                        'Free Parking': 'fa-solid fa-square-parking',
                                        'AC': 'fa-solid fa-snowflake',
                                        'Washer': 'fa-solid fa-jug-detergent',
                                        'TV': 'fa-solid fa-tv',
                                        'Workspace': 'fa-solid fa-laptop',
                                        'Hot Tub': 'fa-solid fa-hot-tub-person',
                                        'BBQ Grill': 'fa-solid fa-fire-burner',
                                        'Gym': 'fa-solid fa-dumbbell',
                                        'Beach Access': 'fa-solid fa-umbrella-beach',
                                        'Fire Pit': 'fa-solid fa-fire',
                                        'Indoor Fireplace': 'fa-solid fa-fire-flame-curved',
                                        'EV Charger': 'fa-solid fa-charging-station',
                                        'Mountain View': 'fa-solid fa-mountain-sun',
                                        'Lake View': 'fa-solid fa-water',
                                        'Garden': 'fa-solid fa-seedling',
                                        'Security Cameras': 'fa-solid fa-camera',
                                        'First Aid Kit': 'fa-solid fa-kit-medical',
                                        'Smoke Alarm': 'fa-solid fa-bell',
                                        'Pets Allowed': 'fa-solid fa-paw',
                                    }; %>
                                    <% for(const amenity of listing.amenities) { %>
                                        <div class="amenity-item">
                                            <i class="<%= amenityIcons[amenity] || 'fa-solid fa-check' %>"></i>
                                            <span><%= amenity %></span>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% } %>

                        <!-- Authorization (Edit/Delete) -->
                        <% if(currUser &&  listing.owner && currUser._id.equals(listing.owner._id)){ %>
                        <div class="btns mt-2">
                            <div class="btns-edit">
                                        <a type="button" href="/listings/<%= listing._id %>/edit"
                                            class="btn btn-dark col-1 offset-3 edit-btn styleBtn">Edit</a>
                                        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE"
                                            class="needs-validation">
                                            <button type="reset" class="btn btn-danger offset-4 del-btn styleBtn"
                                                id="delete-confirm">Delete</button>
                                            <div class="fnx-fixed-dis">
                                                <div class="delete-fnx" style="display: none;">
                                                    <p>I want to delete this listings.</p>
                                                    <p>"<%= listing.title %>"</p>
                                                    <div class="conf cancle-confirm">Cancel</div>
                                                    <button class="conf delete-confirm">Confirm</button>
                                                </div>
                                            </div>
                                        </form>
                            </div>
                        </div>
                        <% } %>
                    </div>

                    <!-- Right: Booking Widget -->
                    <div class="booking-sidebar">
                        <div class="booking-widget">
                            <div class="booking-widget-price" id="listing-price-value" data-price="<%= listing.price %>">
                                &#8377;<%= listing.price.toLocaleString("en-IN") %> <span>/ night</span>
                            </div>

                            <% if(currUser && listing.owner && !currUser._id.equals(listing.owner._id)) { %>
                                <form method="post" action="/listings/<%= listing._id %>/book" id="booking-form">
                                    <div class="booking-form-dates">
                                        <div class="booking-date-input">
                                            <label for="booking-checkin">CHECK-IN</label>
                                            <input type="date" name="checkIn" id="booking-checkin" required>
                                        </div>
                                        <div class="booking-date-input">
                                            <label for="booking-checkout">CHECK-OUT</label>
                                            <input type="date" name="checkOut" id="booking-checkout" required>
                                        </div>
                                    </div>
                                    <div class="booking-guests-input">
                                        <label for="booking-guests">GUESTS</label>
                                        <select name="guests" id="booking-guests">
                                            <% for(let i = 1; i <= (listing.maxGuests || 4); i++) { %>
                                                <option value="<%= i %>"><%= i %> guest<%= i > 1 ? 's' : '' %></option>
                                            <% } %>
                                        </select>
                                    </div>
                                    <button type="submit" class="btn-reserve" id="btn-reserve" disabled>Reserve</button>
                                    <p class="booking-note">You won't be charged yet</p>

                                    <div class="booking-price-summary" id="booking-price-summary" style="display: none;">
                                        <div class="booking-price-row">
                                            <span id="price-nights">-</span>
                                            <span id="price-base">-</span>
                                        </div>
                                        <div class="booking-price-row">
                                            <span>Cleaning fee</span>
                                            <span id="price-cleaning">-</span>
                                        </div>
                                        <div class="booking-price-row">
                                            <span>Service fee</span>
                                            <span id="price-service">-</span>
                                        </div>
                                        <div class="booking-price-row total-row">
                                            <span>Total</span>
                                            <span id="price-total">-</span>
                                        </div>
                                    </div>
                                </form>
                            <% } else if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
                                <div class="login-to-book">
                                    <p style="color:#717171; font-size: 0.9rem;">This is your listing</p>
                                    <a href="/bookings/hosting">View Host Dashboard</a>
                                </div>
                            <% } else { %>
                                <div class="login-to-book">
                                    <p style="color:#717171; font-size: 0.9rem; margin-bottom: 0.75rem;">Log in to book this place</p>
                                    <a href="/login">Log In to Reserve</a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

                <!-- --------------- review ------------- -->
                <hr class="mt-2">
                <div class="col-8 offset-2">
                    <% if(currUser){ %>
                        <p><b>Leave a Review &nbsp;<i class="fa-regular fa-pen-to-square"></i></b></p>
                        <form method="post" action="/listings/<%= listing._id %>/reviews" class="needs-validation"
                            novalidate>
                            <div class=" mt-3">
                                <label class="form-lable" for="rating">Rating</label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="mb-3 ">
                                <label class="form-lable" for="comment">Comment</label>
                                <textarea class="form-control" name="review[comment]" id="comment" cols="30" rows="3"
                                    required></textarea>
                                <div class="invalid-feedback">Please add some comments for review</div>
                            </div>
                            <button class="btn btn-success mb-3 styleBtn">Submit</button>
                        </form>
                        <% } %>
                            <% if(listing.reviews.length> 0 ){ %>
                                <p><b>All Reviews</b></p>
                                <div class="row m-1 review-main">
                                    <% for (const review of listing.reviews) { %>
                                        <div class="card col-xs-4 col-sm-12 col-md-12 col-lg-5 review-lg">
                                            <div class="card-body mb-2 review-card">
                                                <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                                <span style="max-width: 80vw;">
                                                    <h5 class="card-title">@<%= review.author.username %> &nbsp; :</h5>
                                                    <p class="card-text mb-1 review-comment">
                                                        <%= review.comment %>
                                                    </p>
                                                </span>
                                            </div>

                                            <% if(currUser && currUser._id.equals(review.author._id)){ %>
                                                <form
                                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                    class="mb-1 review-del needs-validation" method="post">
                                                    <button class="btn btn-sm btn-danger"><i
                                                            class="fa-solid fa-trash"></i></button>
                                                </form>
                                                <% } %>
                                        </div>
                                        <% } %>
                                </div>
                                <% } %>
                </div>
                <!-- Map Section -->
                <script
                    src="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.0/mapbox-gl-geocoder.min.js"></script>
                <link rel="stylesheet"
                    href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.0/mapbox-gl-geocoder.css"
                    type="text/css">
                <div class="col-8 offset-2 mapImg">
                    <p><b>Where you'll be &nbsp;<i class="fa-solid fa-location-crosshairs"></i></p></b>
                    <div id="map" style="position: relative;">
                        <div class="map-zoom-icon">
                            <div class="icon icon-plus" onclick="zoomin()"><i
                                    class="fa-solid fa-magnifying-glass-plus"></i></div>
                            <div class="icon icon-min" onclick="zoomout()"><i
                                    class="fa-solid fa-magnifying-glass-minus"></i></div>
                        </div>
                    </div>
                    <!-- Map fallback -->
                    <div id="map-fallback" style="display: none;">
                        <div class="map-fallback-card">
                            <i class="fa-solid fa-map-location-dot" style="font-size: 2.5rem; color: #ff385c; margin-bottom: 0.75rem;"></i>
                            <h5><%= listing.location %>, <%= listing.country %></h5>
                            <p style="color: #717171; font-size: 0.9rem;">Exact location provided after booking</p>
                            <% if(listing.geometry && listing.geometry.coordinates) { %>
                                <a href="https://www.google.com/maps?q=<%= listing.geometry.coordinates[1] %>,<%= listing.geometry.coordinates[0] %>" 
                                   target="_blank" class="btn btn-outline-dark btn-sm mt-2">
                                    <i class="fa-solid fa-external-link-alt"></i> View on Google Maps
                                </a>
                            <% } %>
                        </div>
                    </div>
                </div>
        </div>
    </div>
    <script src="/js/map.js"></script>
    <script src="/js/delete-confirm.js"></script>
    <script src="/js/booking.js"></script>